#!/usr/bin/env bash

_mount(){
    sshfs \
        -o default_permissions \
        -o uid=$(id -u) \
        -o gid=$(id -g) \
        -o reconnect \
        -o ServerAliveInterval=15 \
        -o ServerAliveCountMax=3 \
        -o dir_cache=yes \
        -o dcache_max_size=100000 \
        -o dcache_timeout=1200 \
        -o max_conns=4 \
        -o compression=yes \
        $1 $2
}

# 检测并确保挂载点有效（权限为 000 或目录为空时重新挂载）
mount() {
    # help 检查
    if [ "$1" = "-h" ] || [ "$1" = "--help" ] || [ $# -ne 2 ]; then
        echo "用法: _sshfs <本地挂载目录> <远程路径>"
        echo "示例: _sshfs ncti-A6000-1-container-lpt ncti-A6000-1-container-lpt:/"
        return 0
    fi

    local mount_dir="$1"
    local remote_path="$2"

    mkdir -p "$mount_dir"

    # 检查权限是否为 000（失效挂载点特征：d---------）
    local perms=$(stat -c %a "$mount_dir" 2>/dev/null)
    # 检查目录是否为空
    local file_count=$(ls -A "$mount_dir" 2>/dev/null | wc -l)

    if [ "$perms" = "000" ] || [ "$file_count" -eq 0 ]; then
        echo "[$mount_dir] 检测到挂载点失效 (权限=$perms, 文件数=$file_count)，正在重新挂载..."
        fusermount3 -u -z "$mount_dir" 2>/dev/null
        _mount "$remote_path" "$mount_dir"
        echo "[$mount_dir] 重新挂载完成"
    else
        echo "[$mount_dir] 挂载正常"
    fi
}

mount $1 $2
